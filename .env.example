OPENAI_API_KEY=your_openai_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# Auth & Database
SECRET_KEY=change-me-to-a-random-32-char-string
DATABASE_URL=sqlite:///./zarina.db
# For Railway PostgreSQL: DATABASE_URL=postgresql://user:pass@host:port/db

# Email (for password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=your@gmail.com

# Public URL of the Streamlit app (used in reset email link)
APP_URL=http://localhost:8501
